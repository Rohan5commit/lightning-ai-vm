[Unit]
Description=Cloud billing monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/etc/nemoclaw-billing-monitor.env
Environment=PYTHONPATH=/opt/nemoclaw-vm-automation/vendor
ExecStart=/usr/bin/python3 /opt/nemoclaw-vm-automation/billing_monitor.py
WorkingDirectory=/opt/nemoclaw-vm-automation
User=root
Group=root
